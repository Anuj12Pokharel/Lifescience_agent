# =============================================================================
# n8n WORKER — Queue Worker Configuration
# Run on: Each Mac Mini (Edge Spoke)
# =============================================================================
# IMPORTANT: N8N_ENCRYPTION_KEY must be IDENTICAL to the hub master's key

# ── Execution Mode ────────────────────────────────────────────────────────────
EXECUTIONS_MODE=worker

# ── Worker Identity ───────────────────────────────────────────────────────────
# Set this per spoke to identify which worker executed a job
N8N_INSTANCE_TYPE=worker

# ── Encryption (MUST match master) ────────────────────────────────────────────
N8N_ENCRYPTION_KEY=REPLACE_WITH_SAME_64CHAR_HEX_KEY_AS_MASTER

# ── Worker Port (different from master's 5678) ────────────────────────────────
N8N_PORT=5679

# ── Queue (connects to Hub Redis via Tailscale) ───────────────────────────────
# QUEUE_BULL_REDIS_HOST, QUEUE_BULL_REDIS_PASSWORD injected via docker-compose
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=3

# ── Worker concurrency ────────────────────────────────────────────────────────
# How many jobs this worker processes simultaneously
QUEUE_WORKER_TIMEOUT=300
N8N_CONCURRENCY_PRODUCTION_LIMIT=5

# ── Timezone ──────────────────────────────────────────────────────────────────
GENERIC_TIMEZONE=Asia/Kathmandu

# ── Logging ───────────────────────────────────────────────────────────────────
N8N_LOG_LEVEL=info

# ── Disable editor UI on worker (workers don't need the UI) ───────────────────
N8N_EDITOR_ENABLED=false

# ── Execution data pruning ────────────────────────────────────────────────────
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=72

# ── Disable telemetry ─────────────────────────────────────────────────────────
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
