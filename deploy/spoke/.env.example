# =============================================================================
# SPOKE Environment Variables — Mac Mini (Edge Node)
# Copy to: deploy/spoke/.env  (never commit .env to git)
# One copy per Mac Mini — customize SPOKE_ID and credentials per location
# =============================================================================

# ── Spoke Identity ────────────────────────────────────────────────────────────
# Unique ID for this spoke: spoke-a, spoke-b, spoke-c, etc.
SPOKE_ID=spoke-a

# ── Hub Connectivity (via Tailscale VPN) ──────────────────────────────────────
# Get this from hub after running: tailscale ip -4
HUB_TAILSCALE_IP=100.87.29.34

# ── Redis (Hub Task Broker — accessed via Tailscale) ─────────────────────────
REDIS_PASSWORD=a943f08ed598e2b07d64d9a03dd923e9



# ── MinIO (S3-Compatible Local Storage) ───────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=REPLACE_WITH_SECURE_MINIO_PASSWORD

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get this from Cloudflare Zero Trust Dashboard:
#   1. Go to https://one.dash.cloudflare.com
#   2. Access > Tunnels > Create a tunnel
#   3. Name it: spoke-a (or spoke-b for the second Mac Mini)
#   4. Copy the token shown under "Install and run a connector"
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiMDI1NDIwYjY2NzI5NzAzZDRmYWEwYWNiNjA5MDA2NjciLCJ0IjoiYTJkOTBkY2MtNmY4Ny00OTQxLWJmYWMtYmI2NGExM2FhNzZiIiwicyI6IlpXRXdNREkzWVdFdFlqQTJOeTAwTlRoaExXRTRZVEl0T0RsaE9EQmpaR00xWW1JMCJ9

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Auth key from: https://login.tailscale.com/admin/settings/keys
# Use a reusable pre-auth key tagged for spokes
TS_AUTHKEY=tskey-auth-knoFgkHyLw11CNTRL-qPjWaUknvCF9gvR7gK6kCFjXaLPXCzow
