# =============================================================================
# HUB Environment Variables — Contabo Server
# Copy to: deploy/hub/.env  (never commit .env to git)
# =============================================================================

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=YWPWj2iKjSZfg0Cth1jULk2SMF2un2d7LtjAvW8CfIHFyqsIdN
DEBUG=False
ALLOWED_HOSTS=backend.lifescienceaiagents.com,ai.lifescienceaiagents.com,localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ── Hub PostgreSQL ────────────────────────────────────────────────────────────
HUB_DB_USER=hub_user
HUB_DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_NAME=app_db
DB_USER=hub_user
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_HOST=postgres-hub
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ── Spoke MinIO (Edge Storage) ────────────────────────────────────────────────
# Routes all uploaded media/documents from Contabo directly to your Mac Mini!
USE_S3=True
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=REPLACE_WITH_SECURE_MINIO_PASSWORD
MINIO_BUCKET_NAME=lifescience-media
MINIO_PUBLIC_URL=https://storage.lifescienceaiagents.com

# ── Redis (Task Broker) ───────────────────────────────────────────────────────
REDIS_PASSWORD=a943f08ed598e2b07d64d9a03dd923e9
REDIS_URL=redis://:a943f08ed598e2b07d64d9a03dd923e9f@redis:6379/0
CELERY_BROKER_URL=redis://:a943f08ed598e2b07d64d9a03dd923e9@redis:6379/1
CELERY_RESULT_BACKEND=redis://:a943f08ed598e2b07d64d9a03dd923e9@redis:6379/2

# ── CORS (allow spoke frontends via Cloudflare tunnels) ───────────────────────
CORS_ALLOWED_ORIGINS=https://ai.lifescienceaiagents.com,https://client-a.lifescienceaiagents.com,https://client-b.lifescienceaiagents.com

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=REPLACE_WITH_EMAIL
EMAIL_HOST_PASSWORD=REPLACE_WITH_APP_PASSWORD
DEFAULT_FROM_EMAIL=noreply@lifescienceaiagents.com
SERVER_EMAIL=errors@lifescienceaiagents.com

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://ai.lifescienceaiagents.com
BACKEND_URL=https://backend.lifescienceaiagents.com

