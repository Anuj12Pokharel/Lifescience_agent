# =============================================================================
# HUB Caddyfile — Internal Router
# The main server reverse proxy will handle SSL/TLS and forward traffic here
# =============================================================================

{
    auto_https off
}

:80 {
    # ── Django REST API ────────────────────────────────────────────────────────
    @api host api.lifescienceaiagents.com
    handle @api {
        reverse_proxy django-api:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ── n8n MASTER UI/Editor ───────────────────────────────────────────────────
    @n8n host n8n.lifescienceaiagents.com
    handle @n8n {
        reverse_proxy n8n-master:5678 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ── n8n Webhook Endpoint ───────────────────────────────────────────────────
    @webhook host webhook.lifescienceaiagents.com
    handle @webhook {
        reverse_proxy n8n-master:5678 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ── Frontend (Admin & Superadmin) ─────────────────────────────────────────
    @frontend host ai.lifescienceaiagents.com
    handle @frontend {
        reverse_proxy hub-frontend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}
