# =============================================================================
# n8n MASTER — Queue Mode Configuration
# Run on: Contabo Server (Hub)
# =============================================================================
# IMPORTANT: N8N_ENCRYPTION_KEY must be identical across master + all workers

# ── Execution Mode ────────────────────────────────────────────────────────────
EXECUTIONS_MODE=queue

# ── Host / URL ────────────────────────────────────────────────────────────────
N8N_HOST=www.lifescienceaiagents.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://webhook.lifescienceaiagents.com/
N8N_EDITOR_BASE_URL=https://www.lifescienceaiagents.com

# ── Encryption (MUST match all workers) ──────────────────────────────────────
N8N_ENCRYPTION_KEY=REPLACE_WITH_SAME_64CHAR_HEX_KEY_AS_WORKERS

# ── Database (n8n state — separate from app_db) ───────────────────────────────
DB_TYPE=postgresdb
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_db
# DB_POSTGRESDB_HOST and credentials injected via docker-compose environment

# ── Queue (Bull/Redis) ────────────────────────────────────────────────────────
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=3
# QUEUE_BULL_REDIS_HOST and QUEUE_BULL_REDIS_PASSWORD injected via docker-compose

# ── Health & Logging ──────────────────────────────────────────────────────────
N8N_LOG_LEVEL=info
N8N_METRICS=true

# ── Execution Data Pruning ────────────────────────────────────────────────────
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168

# ── Timezone ──────────────────────────────────────────────────────────────────
GENERIC_TIMEZONE=Asia/Kathmandu

# ── Security ──────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Workflow settings ─────────────────────────────────────────────────────────
WORKFLOWS_DEFAULT_NAME=My workflow
N8N_TEMPLATES_ENABLED=true

# ── Disable diagnostics / telemetry ──────────────────────────────────────────
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
